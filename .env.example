ADMIN_EMAIL=admin@induswebagency.com
ADMIN_PASSWORD=Admin@Indus2026!
JWT_SECRET=change-this-to-a-random-secret-in-production
NEXT_PUBLIC_SITE_URL=https://indus-web-agency.vercel.app

# Purchase approval alerts sent here when a customer subscribes
ADMIN_NOTIFICATION_EMAIL=induswebagency@gmail.com

# Gmail SMTP for purchase notification emails (use App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=induswebagency@gmail.com
SMTP_PASS=your-gmail-app-password

# RS256 license signing — set in production (PEM or base64-encoded PEM)
# Generate locally: see docs/LICENSE_SECURITY.md
# LICENSE_PRIVATE_KEY=

# GitHub token for private repo downloads and rate limits (recommended)
# GITHUB_TOKEN=ghp_...

# Optional — persistent storage on Vercel (Upstash Redis)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
